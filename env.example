# Example environment variables for referrals-platform

# Database
APP_DB_DSN=postgresql://appuser:apppass@db:5432/referrals

# Kafka
APP_KAFKA_BROKER=kafka:9092
APP_KAFKA_CLIENT=kafka-python

# Environment
APP_ENV=dev
LOG_LEVEL=DEBUG

# Tenant (multi-tenant scenarios)
TENANT=default

# Crypto (for UCN encryption in referral_code.py)
UCN_ENC_KEY=please-change-me
UCN_SALT=please-change-me-too
