{
  "name": "amplifi-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5173",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 60",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,html}\"",
    "smoke": "node scripts/smoke-check.mjs",
    "test": "vitest run",
    "check": "npm run lint && npm run test && npm run smoke && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
